        "import networkx as nx\n",
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd\n",
        "\n",
        "# ==========================================\n",
        "# 1. Criando os dados\n",
        "# ==========================================\n",
        "\n",
        "dados = [\n",
        "    (\"Carlos\", \"Stranger Things\", 240),\n",
        "    (\"Carlos\", \"Dark\", 15),\n",
        "    (\"Maria\", \"Dark\", 180),\n",
        "    (\"João\", \"Stranger Things\", 220),\n",
        "]\n",
        "\n",
        "df = pd.DataFrame(\n",
        "    dados,\n",
        "    columns=[\"Usuario\", \"Conteudo\", \"Tempo_Assistido\"]\n",
        ")\n",
        "\n",
        "print(\"Dados:\")\n",
        "print(df)\n",
        "\n",
        "# ==========================================\n",
        "# 2. Construindo o grafo\n",
        "# ==========================================\n",
        "\n",
        "G = nx.Graph()\n",
        "\n",
        "for _, row in df.iterrows():\n",
        "    G.add_edge(\n",
        "        row[\"Usuario\"],\n",
        "        row[\"Conteudo\"],\n",
        "        weight=row[\"Tempo_Assistido\"]\n",
        "    )\n",
        "\n",
        "# ==========================================\n",
        "# 3. Degree Centrality\n",
        "# ==========================================\n",
        "\n",
        "centralidade = nx.degree_centrality(G)\n",
        "\n",
        "print(\"\\nDegree Centrality:\")\n",
        "for no, valor in sorted(\n",
        "        centralidade.items(),\n",
        "        key=lambda x: x[1],\n",
        "        reverse=True):\n",
        "    print(f\"{no}: {valor:.3f}\")\n",
        "\n",
        "# ==========================================\n",
        "# 4. Preparando visualização\n",
        "# ==========================================\n",
        "\n",
        "pos = nx.spring_layout(\n",
        "    G,\n",
        "    seed=42,\n",
        "    k=1.5\n",
        ")\n",
        "\n",
        "# Tamanho dos nós baseado na centralidade\n",
        "node_sizes = [\n",
        "    centralidade[node] * 8000 + 1500\n",
        "    for node in G.nodes()\n",
        "]\n",
        "\n",
        "# Espessura das arestas baseada no peso\n",
        "edge_weights = [\n",
        "    G[u][v][\"weight\"] / 40\n",
        "    for u, v in G.edges()\n",
        "]\n",
        "\n",
        "# Rótulos das arestas\n",
        "edge_labels = nx.get_edge_attributes(\n",
        "    G,\n",
        "    \"weight\"\n",
        ")\n",
        "\n",
        "# ==========================================\n",
        "# 5. Plotando o grafo\n",
        "# ==========================================\n",
        "\n",
        "plt.figure(figsize=(12, 8))\n",
        "\n",
        "nx.draw_networkx_nodes(\n",
        "    G,\n",
        "    pos,\n",
        "    node_size=node_sizes\n",
        ")\n",
        "\n",
        "nx.draw_networkx_edges(\n",
        "    G,\n",
        "    pos,\n",
        "    width=edge_weights\n",
        ")\n",
        "\n",
        "nx.draw_networkx_labels(\n",
        "    G,\n",
        "    pos,\n",
        "    font_size=11,\n",
        "    font_weight=\"bold\"\n",
        ")\n",
        "\n",
        "nx.draw_networkx_edge_labels(\n",
        "    G,\n",
        "    pos,\n",
        "    edge_labels=edge_labels\n",
        ")\n",
        "\n",
        "plt.title(\n",
        "    \"Grafo de Interações de Usuários e Conteúdos\",\n",
        "    fontsize=16\n",
        ")\n",
        "\n",
        "plt.axis(\"off\")\n",
        "plt.tight_layout()\n",
        "\n",
        "plt.show()\n",
        "\n",
        "# ==========================================\n",
        "# 6. Ranking de usuários\n",
        "# ==========================================\n",
        "\n",
        "usuarios = [\"Carlos\", \"Maria\", \"João\"]\n",
        "\n",
        "ranking = pd.DataFrame({\n",
        "    \"Usuário\": usuarios,\n",
        "    \"Centralidade\": [\n",
        "        centralidade[u]\n",
        "        for u in usuarios\n",
        "    ]\n",
        "})\n",
        "\n",
        "ranking = ranking.sort_values(\n",
        "    \"Centralidade\",\n",
        "    ascending=False\n",
        ")\n",
        "\n",
        "print(\"\\nRanking de Engajamento:\")\n",
        "print(ranking)\n",
        "\n",
        "# ==========================================\n",
        "# 7. Simulação de queda de engajamento\n",
        "# ==========================================\n",
        "\n",
        "print(\"\\n--- Simulação de Churn ---\")\n",
        "\n",
        "G2 = G.copy()\n",
        "\n",
        "G2.remove_edge(\n",
        "    \"Carlos\",\n",
        "    \"Dark\"\n",
        ")\n",
        "\n",
        "nova_centralidade = nx.degree_centrality(G2)\n",
        "\n",
        "print(\n",
        "    f\"Centralidade original de Carlos: \"\n",
        "    f\"{centralidade['Carlos']:.3f}\"\n",
        ")\n",
        "\n",
        "print(\n",
        "    f\"Centralidade após perder interação: \"\n",
        "    f\"{nova_centralidade['Carlos']:.3f}\"\n",
        ")"
      ]
